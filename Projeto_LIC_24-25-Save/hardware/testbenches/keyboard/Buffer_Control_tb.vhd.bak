library ieee;
use ieee.std_logic_1164.all;

entity Buffer_Control_tb is
end Buffer_Control_tb;

architecture behavioral of Buffer_Control_tb is
	
component Buffer_Control is
	port(
		reset 	: in std_logic;
		clk		: in std_logic;
		Load		: in std_logic;
		Ack	: in std_logic;
		Obfree		: out std_logic;
		Dval		: out std_logic;
		Wreg		: out std_logic
);
end component;

constant mclk_period : time := 20 ns;
constant mclk_half_period : time := mclk_period / 2;


signal 		reset_tb 		: std_logic;
signal		clk_tb			: std_logic;
signal		Load_tb			: std_logic;
signal		Ack_tb		   : std_logic_vector(4 downto 0);
signal		Obfree_tb		   : std_logic;
signal		Dval_tb		   : std_logic_vector(4 downto 0);
signal		Wreg_tb			: std_logic;

begin
   uut : Buffer_Control
	port map (
			reset => reset_tb,
			clk	=> clk_tb,
			Dval  => Dval_tb,
			Ack => Ack_tb,
			Wreg => Wreg_tb,
			Obfree => Obfree_tb,
			Load => Load_tb
	);
	
	clk_process : process
	begin
		while true loop
            clk_tb <= '1';
            wait for mclk_half_period;
            clk_tb <= '0';
            wait for mclk_half_period;
        end loop;
    end process;
	
	stimulus : process
	begin
		  reset_tb <= '1';
        wait for mclk_period;
        reset_tb <= '0';

		  
		  
        Load_tb <= '0';
        wait for mclk_period;

		  Load_tb <= '0';
        wait for mclk_half_period*5;
		  
		  Load_tb <= '1';
		  wait for mclk_period;
		  
        Load_tb <= '1';
        wait for mclk_half_period;

		  
		  Ack_tb <= '1';
		  wait for mclk_half_period*5;
		  
		  Ack_tb <= '0';
		  wait for mclk_half_period*7;
		  

        wait;
    end process;

end behavioral;
	